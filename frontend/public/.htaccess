<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Keep real files and directories (JS, CSS, images) untouched.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # React Router handles every other browser route.
  RewriteRule ^ index.html [L]
</IfModule>
