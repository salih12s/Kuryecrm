// KuryeCrm - Prisma schema (Phase 1)
// Only the core auth/user/panel models are defined here.
// Operational models (shifts, advances, current accounts, income/expense,
// reporting) belong to later phases and are intentionally omitted.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RESTAURANT
  COURIER
  KURYE_SEFI
  PARTNER
  // Accountant: sees only the Restoran Cari (restaurant accounts) screen and
  // can create/edit invoices+payments there to issue weekly invoices.
  MUHASEBE
  // Marketer: logs their own field-visit outcomes (positive/negative), sees
  // only their own entries.
  PAZARLAMACI
  // Restricted admin: full read access to everything an admin sees, but every
  // write endpoint rejects this role (enforced by ReadOnlyGuard/FinanceWriteGuard).
  GOZLEMCI
}

enum VisitResult {
  POSITIVE
  NEGATIVE
}

// Approval lifecycle for records created by a Kurye Şefi. Records created by an
// admin are APPROVED immediately; Kurye Şefi creations start PENDING and stay
// inactive until an admin approves them.
enum ApprovalStatus {
  APPROVED
  PENDING
  REJECTED
}

enum ShiftStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum ShiftConfirmationStatus {
  WAITING
  RESTAURANT_SUBMITTED
  COURIER_SUBMITTED
  MATCHED
  DISPUTED
  ADMIN_APPROVED
}

enum AdvanceStatus {
  ACTIVE
  CANCELLED
}

enum FinanceTransactionType {
  INCOME
  EXPENSE
}

enum FinanceTransactionStatus {
  ACTIVE
  CANCELLED
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  CANCELLED
}

enum PaymentStatus {
  ACTIVE
  CANCELLED
}

enum CourierPaymentStatus {
  ACTIVE
  CANCELLED
}

// ----------------------- Stock (Phase 6) -----------------------
// Lifecycle of a motorcycle in the company asset register.
enum MotorcycleStatus {
  IN_STOCK // henüz kullanımda/satışta değil, depoda
  ASSIGNED // operasyonda kullanılıyor
  SOLD     // satıldı (salePrice/saleDate dolu)
}

// Accessory product kinds we buy and resell.
enum AccessoryType {
  BAG        // çanta
  CHEST_BAG  // göğüs çantası
  OTHER      // diğer aksesuarlar
}

model User {
  id           String   @id @default(uuid())
  name         String
  username     String   @unique
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // One-to-one relations to role-specific profiles.
  restaurant Restaurant?
  courier    Courier?

  // Field-visit log entries created by this user when role = PAZARLAMACI.
  marketingVisits MarketingVisit[]

  @@map("users")
}

model Restaurant {
  id              String   @id @default(uuid())
  userId          String   @unique
  name            String
  authorizedPerson String
  phone           String
  address         String
  hourlyRate      Decimal  @default(0) @db.Decimal(10, 2)
  isActive        Boolean  @default(true)
  approvalStatus  ApprovalStatus @default(APPROVED)
  rejectionNote   String?

  // Fixed restaurant location, picked from a map on create/edit.
  latitude     Float?
  longitude    Float?
  locationNote String?

  // Soft delete: set instead of removing the row, so historical shifts and
  // finance records (and therefore reports) are preserved after "deletion".
  deletedAt       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  shifts    Shift[]
  segments  ShiftSegment[]
  invoices  RestaurantInvoice[]
  payments  RestaurantPayment[]
  locations CourierLocation[]

  @@map("restaurants")
}

model Courier {
  id         String   @id @default(uuid())
  userId     String   @unique
  name       String
  phone      String
  plate      String?
  hourlyRate Decimal  @default(0) @db.Decimal(10, 2)
  isActive   Boolean  @default(true)
  approvalStatus ApprovalStatus @default(APPROVED)
  rejectionNote  String?
  // Soft delete: preserves historical shifts/finance (and reports) after delete.
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  shifts    Shift[]
  advances  CourierAdvance[]
  payments  CourierPayment[]
  locations CourierLocation[]
  // Stock items (accessories / motorcycles) sold to this courier; their amount
  // is charged against the courier's earnings (hak ediş).
  accessorySales  AccessorySale[]
  motorcycleSales Motorcycle[]

  @@map("couriers")
}

model Shift {
  id           String @id @default(uuid())
  restaurantId String
  courierId    String

  // Stored as plain strings to stay timezone-agnostic and match the
  // frontend formats directly: date = "YYYY-MM-DD", times = "HH:mm".
  date             String
  plannedStartTime String
  plannedEndTime   String
  extraStartTime   String?
  extraEndTime     String?

  // Hourly-rate snapshots taken at creation time. Later profile rate changes
  // must NOT alter the accounting of past shifts (used in Phase 4/5).
  restaurantHourlyRateSnapshot Decimal @db.Decimal(10, 2)
  courierHourlyRateSnapshot    Decimal @db.Decimal(10, 2)

  // What each party reported.
  restaurantReportedStartTime String?
  restaurantReportedEndTime   String?
  courierReportedStartTime    String?
  courierReportedEndTime      String?

  // Final times the admin approves; all real money math uses these.
  approvedStartTime String?
  approvedEndTime   String?

  status             ShiftStatus             @default(PLANNED)
  confirmationStatus ShiftConfirmationStatus @default(WAITING)

  note      String?
  adminNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  courier    Courier           @relation(fields: [courierId], references: [id], onDelete: Cascade)
  segments   ShiftSegment[]
  locations  CourierLocation[]

  @@index([restaurantId])
  @@index([courierId])
  @@index([date])
  @@map("shifts")
}

// A single shift can be worked across more than one restaurant. Each segment
// is one continuous work interval at one restaurant within the shift.
// Shifts with NO segments are treated as a single interval at Shift.restaurantId
// (backward compatible: historical shifts keep their original accounting).
model ShiftSegment {
  id           String @id @default(uuid())
  shiftId      String
  restaurantId String

  // Rate snapshot frozen when the segment is created, so later profile rate
  // changes do not rewrite the accounting of this segment.
  restaurantHourlyRateSnapshot Decimal @db.Decimal(10, 2)

  // "HH:mm". endTime null means the segment is the currently-open one (the
  // courier is still working at this restaurant until the shift's end time).
  startTime String
  endTime   String?
  sequence  Int

  createdAt DateTime @default(now())

  shift      Shift      @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([shiftId])
  @@index([restaurantId])
  @@map("shift_segments")
}

// ----------------------- Finance (Phase 4) -----------------------
// Money amounts use Decimal(12,2). Dates are "YYYY-MM-DD" strings, consistent
// with the Shift model, for timezone-free storage and easy range filtering.

model CourierAdvance {
  id          String        @id @default(uuid())
  courierId   String
  amount      Decimal       @db.Decimal(12, 2)
  advanceDate String
  note        String?
  status      AdvanceStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  courier Courier @relation(fields: [courierId], references: [id], onDelete: Cascade)

  @@index([courierId])
  @@index([status])
  @@map("courier_advances")
}

model CourierPayment {
  id          String               @id @default(uuid())
  courierId   String
  amount      Decimal              @db.Decimal(12, 2)
  paymentDate String
  method      String?
  note        String?
  status      CourierPaymentStatus @default(ACTIVE)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  courier Courier @relation(fields: [courierId], references: [id], onDelete: Cascade)

  @@index([courierId])
  @@index([paymentDate])
  @@index([status])
  @@map("courier_payments")
}

model RestaurantInvoice {
  id           String        @id @default(uuid())
  restaurantId String
  invoiceNo    String?
  invoiceDate  String
  periodStart  String?
  periodEnd    String?
  amount       Decimal       @db.Decimal(12, 2)
  note         String?
  status       InvoiceStatus @default(UNPAID)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  restaurant Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  payments   RestaurantPayment[]

  @@index([restaurantId])
  @@index([status])
  @@map("restaurant_invoices")
}

model RestaurantPayment {
  id           String        @id @default(uuid())
  restaurantId String
  invoiceId    String?
  paymentDate  String
  amount       Decimal       @db.Decimal(12, 2)
  method       String?
  note         String?
  status       PaymentStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  restaurant Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  invoice    RestaurantInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([invoiceId])
  @@index([status])
  @@map("restaurant_payments")
}

model FinanceTransaction {
  id              String                   @id @default(uuid())
  type            FinanceTransactionType
  title           String
  category        String?
  amount          Decimal                  @db.Decimal(12, 2)
  transactionDate String
  note            String?
  status          FinanceTransactionStatus @default(ACTIVE)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([type])
  @@index([status])
  @@map("finance_transactions")
}

// ----------------------- Stock (Phase 6) -----------------------
// Motorcycle asset register. A plain record of bikes the company bought, with
// an optional sale. Money uses Decimal(12,2); dates are "YYYY-MM-DD" strings,
// consistent with the finance models.
model Motorcycle {
  id            String           @id @default(uuid())
  brand         String // marka / model, örn. "Honda Activa"
  plate         String?
  purchaseDate  String // YYYY-MM-DD
  purchasePrice Decimal          @db.Decimal(12, 2)
  status        MotorcycleStatus @default(IN_STOCK)

  // Filled only when status = SOLD. Sale profit = salePrice - purchasePrice.
  saleDate  String?
  salePrice Decimal? @db.Decimal(12, 2)

  // Buyer: free-text name and/or a linked courier. When a courier is linked the
  // sale price is charged against that courier's earnings (hak ediş).
  buyer          String?
  buyerCourierId String?
  buyerCourier   Courier? @relation(fields: [buyerCourierId], references: [id], onDelete: SetNull)

  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([buyerCourierId])
  @@map("motorcycles")
}

// One accessory purchase (we bought N units of a type at unitCost). Increases
// stock on hand for that type.
model AccessoryPurchase {
  id           String        @id @default(uuid())
  type         AccessoryType
  name         String? // serbest etiket, örn. "Kırmızı termal çanta"
  quantity     Int
  unitCost     Decimal       @db.Decimal(12, 2)
  purchaseDate String
  supplier     String?
  note         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([type])
  @@index([purchaseDate])
  @@map("accessory_purchases")
}

// One accessory sale. Both the sale unit price and the cost-basis unit price
// are stored on the row, so profit is explicit and independent of any later
// purchase edits: profit = (unitPrice - unitCost) * quantity. Decreases stock.
model AccessorySale {
  id        String        @id @default(uuid())
  type      AccessoryType
  name      String?
  quantity  Int
  unitPrice Decimal       @db.Decimal(12, 2) // satış birim fiyatı
  unitCost  Decimal       @db.Decimal(12, 2) // alış (maliyet) birim fiyatı
  saleDate  String
  buyer     String?
  // When the buyer is a registered courier, the sale revenue is charged against
  // that courier's earnings (hak ediş).
  buyerCourierId String?
  buyerCourier   Courier? @relation(fields: [buyerCourierId], references: [id], onDelete: SetNull)
  note      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([type])
  @@index([saleDate])
  @@index([buyerCourierId])
  @@map("accessory_sales")
}

// ----------------------- Live tracking -----------------------
// One GPS ping from a courier's device. Only recorded while the courier has an
// active shift; outside an active shift the backend rejects pings, so no
// location is stored when the courier is off-duty.
model CourierLocation {
  id           String  @id @default(uuid())
  courierId    String
  shiftId      String
  restaurantId String?

  latitude  Float
  longitude Float
  speed     Float?
  accuracy  Float?

  // Free-text device/connection hints reported by the client.
  deviceStatus     String?
  connectionStatus String?

  // recordedAt = client device timestamp; createdAt = server receive time.
  recordedAt DateTime
  createdAt  DateTime @default(now())

  courier    Courier     @relation(fields: [courierId], references: [id], onDelete: Cascade)
  shift      Shift       @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)

  @@index([courierId, createdAt])
  @@index([shiftId])
  @@map("courier_locations")
}

// ----------------------- Marketing (Pazarlama) -----------------------
// One field-visit outcome logged by a Pazarlamacı (marketer). Each row belongs
// to the marketer who created it; marketers only ever see their own rows.
model MarketingVisit {
  id        String @id @default(uuid())
  userId    String

  visitDate String // YYYY-MM-DD, consistent with Shift/finance date storage
  placeName String // ziyaret edilen işletme/yer adı
  contactName String?
  phone       String?

  result         VisitResult
  // Sonuç POSITIVE ise doldurulur: kaç kişilik operasyon.
  operationSize  Int?
  // Sonuç NEGATIVE ise doldurulur: olumsuzluk nedeni.
  negativeReason String?
  note           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([visitDate])
  @@map("marketing_visits")
}

// Simple key/value application settings (tracking interval, offline threshold,
// partner finance-edit toggle). Missing keys fall back to code defaults.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}
